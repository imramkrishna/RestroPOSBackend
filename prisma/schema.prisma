// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  CHEF
  WAITER
}

enum StaffStatus {
  ACTIVE
  LEAVE
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  COOKING
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  OTHER
}

enum OrderChannel {
  DINE_IN
  TAKEAWAY
  ONLINE
}

enum DeliveryProvider {
  PATHAO_FOOD
  FOOD_MANDU
  OTHER
}

enum SettlementStatus {
  PENDING
  SETTLED
  DISPUTED
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  passwordHash  String         @map("password_hash")
  role          UserRole
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  
  profile       StaffProfile?
  orders        Order[]

  @@map("users")
}

model StaffProfile {
  id          String       @id @default(uuid())
  userId      String       @unique @map("user_id")
  fullName    String       @map("full_name")
  phone       String?
  avatarUrl   String?      @map("avatar_url")
  status      StaffStatus  @default(ACTIVE)
  shiftStart  String?      @map("shift_start")
  shiftEnd    String?      @map("shift_end")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_profiles")
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  icon      String?
  imageUrl  String?    @map("image_url")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String      @id @default(uuid())
  categoryId  String      @map("category_id")
  name        String
  description String?
  price       Float
  imageUrl    String?     @map("image_url")
  isAvailable Boolean     @default(true) @map("is_available")
  sizes       Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("menu_items")
}

model Table {
  id           String        @id @default(uuid())
  tableNumber  String        @unique @map("table_number")
  capacity     Int
  status       TableStatus   @default(AVAILABLE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  
  orders       Order[]
  reservations Reservation[]

  @@map("tables")
}

model Reservation {
  id           String            @id @default(uuid())
  tableId      String            @map("table_id")
  customerName String            @map("customer_name")
  phone        String
  guestCount   Int               @map("guest_count")
  datetime     DateTime
  status       ReservationStatus @default(PENDING)
  notes        String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  
  table        Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("reservations")
}

model Inventory {
  id            String   @id @default(uuid())
  itemName      String   @map("item_name")
  category      String
  quantity      Float
  unit          String
  minStockLevel Float    @map("min_stock_level")
  costPrice     Float    @map("cost_price")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("inventory")
}

model Order {
  id            String        @id @default(uuid())
  tableId       String?       @map("table_id")
  staffId       String        @map("staff_id")
  channel       OrderChannel  @default(DINE_IN)
  status        OrderStatus   @default(PENDING)
  subtotal      Float
  tax           Float
  total         Float
  paymentMethod PaymentMethod?  @map("payment_method")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  table         Table?        @relation(fields: [tableId], references: [id])
  staff         User          @relation(fields: [staffId], references: [id])
  onlineDetails OnlineOrderDetails?
  orderItems    OrderItem[]

  @@index([channel, createdAt])
  @@map("orders")
}

model OnlineOrderDetails {
  id                     String           @id @default(uuid())
  orderId                String           @unique @map("order_id")
  provider               DeliveryProvider
  externalOrderId        String?          @map("external_order_id")
  customerName           String           @map("customer_name")
  customerPhone          String           @map("customer_phone")
  deliveryAddress        String           @map("delivery_address")
  deliveryInstructions   String?          @map("delivery_instructions")
  providerGrossAmount    Float?           @map("provider_gross_amount")
  providerCommission     Float?           @map("provider_commission")
  providerDeliveryFee    Float?           @map("provider_delivery_fee")
  providerDiscount       Float?           @map("provider_discount")
  expectedPayout         Float?           @map("expected_payout")
  settlementStatus       SettlementStatus @default(PENDING) @map("settlement_status")
  settledAt              DateTime?        @map("settled_at")
  settlementBatchId      String?          @map("settlement_batch_id")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  order                  Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  settlementBatch        SettlementBatch? @relation(fields: [settlementBatchId], references: [id], onDelete: SetNull)

  @@unique([provider, externalOrderId])
  @@index([provider, settlementStatus])
  @@index([provider, createdAt])
  @@index([settlementBatchId])
  @@map("online_order_details")
}

model SettlementBatch {
  id               String             @id @default(uuid())
  provider         DeliveryProvider
  weekStart        DateTime           @map("week_start")
  weekEnd          DateTime           @map("week_end")
  orderCount       Int                @default(0) @map("order_count")
  grossAmount      Float              @default(0) @map("gross_amount")
  commissionAmount Float              @default(0) @map("commission_amount")
  netAmount        Float              @default(0) @map("net_amount")
  notes            String?
  settledAt        DateTime           @default(now()) @map("settled_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  onlineOrders     OnlineOrderDetails[]

  @@unique([provider, weekStart, weekEnd])
  @@index([provider, weekStart])
  @@map("settlement_batches")
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  menuItemId   String   @map("menu_item_id")
  quantity     Int
  variant      String?
  priceAtTime  Float    @map("price_at_time")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}
